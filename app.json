{
  "expo": {
    "name": "Eduverse Mobile",
    "slug": "eduverse-mobile-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "eduverse",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#f8fafc"
    },
    "ios": {
      "bundleIdentifier": "com.eduverse.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Eduverse uses the camera for live class sessions.",
        "NSMicrophoneUsageDescription": "Eduverse uses the microphone for live class sessions."
      },
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.eduverse.mobile",
      "permissions": ["CAMERA", "RECORD_AUDIO"],
      "softwareKeyboardLayoutMode": "resize"
    },
    "plugins": [
      "expo-notifications",
      "@livekit/react-native-expo-plugin",
      "@config-plugins/react-native-webrtc",
      "./plugins/withDisableIosUserScriptSandboxing"
    ],
    "web": {
      "bundler": "metro"
    }
  }
}
